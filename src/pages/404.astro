---
import BaseLayout from '../layouts/BaseLayout.astro';
import { byId } from '../data/tests';

const title = 'Page Not Found | The Reflex Hub';
const description =
  'That page missed the target. Head back to The Reflex Hub for free reaction time, CPS, typing, memory, and aim tests with instant scores.';

const suggestions = ['reaction', 'cps', 'typing', 'aim'].map(byId);
---

<BaseLayout title={title} description={description} path="/404" noindex>
  <section class="mx-auto flex max-w-6xl flex-col items-center px-4 pt-16 text-center">
    <p class="score-nums text-8xl font-bold text-accent sm:text-9xl" aria-hidden="true">404</p>
    <h1 class="mt-4 font-display text-2xl font-bold sm:text-3xl">This Page Missed the Target</h1>
    <p class="mt-3 max-w-md leading-relaxed text-muted">
      The page you are looking for does not exist, was moved, or never spawned. Your reflexes are fine; our targets
      are not always where you expect them.
    </p>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <a href="/" class="btn btn-primary">Back to all tests</a>
      <a href="/reaction-time-test" class="btn btn-ghost">Test your reaction time</a>
    </div>

    <div class="mt-12 w-full max-w-3xl">
      <p class="text-xs font-bold uppercase tracking-widest text-muted">Popular right now</p>
      <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {suggestions.map((test) => (
          <a href={test.href} class="card press group flex items-center gap-3 p-4 text-left transition-shadow hover:shadow-glow">
            <span class="inline-flex size-10 shrink-0 items-center justify-center rounded-xl bg-surface2 text-accent transition-colors group-hover:bg-accent group-hover:text-bg">
              <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true" set:html={test.icon} />
            </span>
            <span class="font-display font-bold">{test.title}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
