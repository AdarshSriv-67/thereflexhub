---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Something Went Wrong | The Reflex Hub';
const description =
  'Something went wrong on our side. Refresh the page or head back to The Reflex Hub for free reaction, typing, memory, and aim tests.';
---

<BaseLayout title={title} description={description} path="/500" noindex>
  <section class="mx-auto flex max-w-6xl flex-col items-center px-4 pt-16 text-center">
    <p class="score-nums text-8xl font-bold text-bad sm:text-9xl" aria-hidden="true">500</p>
    <h1 class="mt-4 font-display text-2xl font-bold sm:text-3xl">False Start on Our Side</h1>
    <p class="mt-3 max-w-md leading-relaxed text-muted">
      Something went wrong on the server, and this one is on us, not your reflexes. It is usually temporary: a refresh
      brings most pages straight back.
    </p>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <button type="button" onclick="location.reload()" class="btn btn-primary">Try again</button>
      <a href="/" class="btn btn-ghost">Back to all tests</a>
    </div>
    <p class="mt-8 text-sm text-muted">
      Still broken after a refresh? <a href="/contact" class="text-accent underline underline-offset-2">Tell us</a> and
      we will fix it.
    </p>
  </section>
</BaseLayout>
