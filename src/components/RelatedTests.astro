---
import { byId } from '../data/tests';

interface Props {
  /** Exactly four sibling test ids from src/data/tests.ts */
  ids: string[];
  heading?: string;
}

const { ids, heading = 'Try These Next' } = Astro.props;
const related = ids.map(byId);
---

<section class="mx-auto mt-12 max-w-6xl px-4" aria-label="Related tests">
  <h2 class="mb-5 font-display text-2xl font-bold">{heading}</h2>
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {related.map((test) => (
      <a href={test.href} class="card press group flex flex-col gap-2 p-4 transition-shadow hover:shadow-glow">
        <span class="flex items-center gap-2 font-display font-bold">
          <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" class="text-accent" set:html={test.icon} />
          {test.title}
        </span>
        <span class="text-sm text-muted">{test.hook}</span>
      </a>
    ))}
  </div>
</section>
