---
// Shared stats-and-history shell, populated by src/games/statsPanel.ts via
// data-sp-* hooks. Hidden until at least one run exists in localStorage.
interface Props {
  id?: string;
  heading?: string;
  /** title over the per-run bar chart; omit for games without per-item times */
  runChartTitle?: string;
  historyTitle?: string;
}

const {
  id = 'stats-panel',
  heading = 'Your Stats and History',
  runChartTitle,
  historyTitle = 'Last 20 runs',
} = Astro.props;
---

<div id={id} class="card mt-6 hidden w-full p-5 sm:p-6" data-stats-panel>
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h2 class="font-display text-lg font-bold">{heading}</h2>
    <button
      type="button"
      class="btn btn-ghost min-h-9 px-3 py-1.5 text-xs font-medium text-muted transition-colors hover:text-bad"
      data-sp-clear
    >
      Clear history
    </button>
  </div>
  <div class="mt-4 grid gap-8 lg:grid-cols-2">
    {
      runChartTitle && (
        <div class="hidden" data-sp-run-block>
          <p class="text-xs font-bold uppercase tracking-widest text-muted">{runChartTitle}</p>
          <div class="mt-3" data-sp-run-chart />
          <p class="score-nums mt-2 text-xs text-muted" data-sp-run-note />
        </div>
      )
    }
    <div class="hidden" data-sp-hist-block>
      <p class="text-xs font-bold uppercase tracking-widest text-muted">{historyTitle}</p>
      <div class="mt-3" data-sp-hist-chart></div>
      <p class="mt-2 text-xs text-muted">Hover a point for the full run details.</p>
    </div>
  </div>
  <div class="mt-6 hidden" data-sp-table-block>
    <p class="text-xs font-bold uppercase tracking-widest text-muted">Recent runs</p>
    <div class="mt-3 overflow-x-auto rounded-xl border border-line">
      <table class="w-full min-w-[420px] text-sm">
        <thead>
          <tr class="bg-surface2 text-left font-display" data-sp-head></tr>
        </thead>
        <tbody class="score-nums text-muted" data-sp-rows></tbody>
      </table>
    </div>
  </div>
</div>

<style is:global>
  [data-sp-run-chart] svg rect:hover {
    opacity: 1;
  }
</style>
