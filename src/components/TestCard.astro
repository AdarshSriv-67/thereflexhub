---
import type { TestMeta } from '../data/tests';

interface Props {
  test: TestMeta;
}

const { test } = Astro.props;
---

<a
  href={test.href}
  class="card press group flex flex-col gap-3 p-5 transition-shadow hover:shadow-glow"
>
  <span class="inline-flex size-11 items-center justify-center rounded-xl bg-surface2 text-accent transition-colors group-hover:bg-accent group-hover:text-bg">
    <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true" set:html={test.icon} />
  </span>
  <span class="font-display text-lg font-bold">{test.title}</span>
  <span class="text-sm leading-relaxed text-muted">{test.hook}</span>
</a>
