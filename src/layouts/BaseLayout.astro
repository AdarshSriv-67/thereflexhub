---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import { tests } from '../data/tests';

interface Props {
  title: string;
  description: string;
  path: string;
  schema?: Record<string, unknown>[];
  ogImage?: string;
  noindex?: boolean;
}

const { title, description, path, schema = [], ogImage = '/og-default.png', noindex = false } = Astro.props;
const canonical = new URL(path === '/' ? '/' : path, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;

const navLinks = [
  { label: 'Reaction', href: '/reaction-time-test' },
  { label: 'Clicking', href: '/cps-test' },
  { label: 'Typing', href: '/typing-test' },
  { label: 'Memory', href: '/memory-test' },
  { label: 'Aim', href: '/aim-trainer' },
  { label: '2048', href: '/2048' },
];

const footerGroups: { heading: string; links: { label: string; href: string }[] }[] = [
  {
    heading: 'Reaction and Clicking',
    links: tests
      .filter((t) => t.category === 'reaction' || t.category === 'clicking')
      .map((t) => ({ label: t.title, href: t.href })),
  },
  {
    heading: 'Typing and Brain',
    links: tests
      .filter((t) => t.category === 'typing' || t.category === 'brain')
      .map((t) => ({ label: t.title, href: t.href })),
  },
  {
    heading: 'More Games',
    links: [
      ...tests.filter((t) => t.category === 'aim' || t.category === 'puzzle').map((t) => ({ label: t.title, href: t.href })),
      { label: 'All Tests', href: '/' },
    ],
  },
  {
    heading: 'Site',
    links: [
      { label: 'About', href: '/about' },
      { label: 'Privacy Policy', href: '/privacy-policy' },
      { label: 'Terms and Conditions', href: '/terms-and-conditions' },
      { label: 'Contact', href: '/contact' },
    ],
  },
];
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="ReflexHub" />
    <link rel="manifest" href="/site.webmanifest" />
    <link
      rel="preload"
      href="/fonts/space-grotesk-latin-700-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <meta name="theme-color" content="#0B0F1A" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="The Reflex Hub" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script is:inline>
      (function () {
        var theme = 'dark';
        try {
          var stored = localStorage.getItem('trh:theme');
          if (stored === 'light' || stored === 'dark') {
            theme = stored;
          } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
            theme = 'light';
          }
        } catch (e) {}
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>

    {
      schema.map((block) => (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(block)} />
      ))
    }

    <!-- Plausible Analytics: paste the script tag for thereflexhub.com here -->
    <!-- <script defer data-domain="thereflexhub.com" src="https://plausible.io/js/script.js"></script> -->
  </head>
  <body class="bg-bg text-ink font-body flex min-h-dvh flex-col">
    <header class="sticky top-0 z-50 border-b border-line bg-bg/75 backdrop-blur-md">
      <div class="mx-auto flex h-14 max-w-6xl items-center gap-4 px-4">
        <a href="/" class="flex items-center gap-2 font-display text-lg font-bold tracking-tight" aria-label="The Reflex Hub home">
          <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true" class="text-accent drop-shadow-[0_0_6px_var(--accent)]">
            <path d="M13 2 4.5 13.5H11L9.5 22 19 10h-6.5L13 2Z" fill="currentColor" />
          </svg>
          <span>The Reflex <span class="text-accent">Hub</span></span>
        </a>
        <nav class="ml-auto hidden items-center gap-1 md:flex" aria-label="Test categories">
          {navLinks.map((l) => (
            <a
              href={l.href}
              class="rounded-lg px-3 py-2 text-sm font-medium text-muted transition-colors hover:bg-surface2 hover:text-ink"
            >
              {l.label}
            </a>
          ))}
        </nav>
        <div class="ml-auto flex items-center gap-3 md:ml-0">
          <ThemeToggle />
          <button
            id="menu-btn"
            type="button"
            class="press tap-target inline-flex items-center justify-center rounded-lg text-muted transition-colors hover:bg-surface2 hover:text-ink md:hidden"
            aria-label="Open menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <svg id="menu-icon-open" class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
              <path d="M4 7h16M4 12h16M4 17h16" />
            </svg>
            <svg id="menu-icon-close" class="hidden size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
              <path d="M6 6l12 12M18 6 6 18" />
            </svg>
          </button>
        </div>
      </div>

      <nav id="mobile-menu" class="hidden border-t border-line md:hidden" aria-label="Mobile navigation">
        <ul class="mx-auto grid max-w-6xl grid-cols-2 gap-1 px-4 py-3">
          {[{ label: 'All Tests', href: '/' }, ...navLinks, { label: 'About', href: '/about' }, { label: 'Contact', href: '/contact' }].map((l) => (
            <li>
              <a
                href={l.href}
                class="block rounded-lg px-3 py-3 text-sm font-medium text-muted transition-colors hover:bg-surface2 hover:text-ink"
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <script>
      const menuBtn = document.getElementById('menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const iconOpen = document.getElementById('menu-icon-open');
      const iconClose = document.getElementById('menu-icon-close');

      function setMenuOpen(open: boolean): void {
        mobileMenu?.classList.toggle('hidden', !open);
        iconOpen?.classList.toggle('hidden', open);
        iconClose?.classList.toggle('hidden', !open);
        menuBtn?.setAttribute('aria-expanded', String(open));
        menuBtn?.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      }

      menuBtn?.addEventListener('click', () => {
        setMenuOpen(mobileMenu?.classList.contains('hidden') ?? false);
      });
      mobileMenu?.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('a')) setMenuOpen(false);
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && mobileMenu && !mobileMenu.classList.contains('hidden')) setMenuOpen(false);
      });
    </script>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="mt-16 border-t border-line bg-surface">
      <div class="mx-auto max-w-6xl px-4 py-10">
        <div class="mb-8 flex flex-col gap-2">
          <a href="/" class="flex w-fit items-center gap-2 font-display text-lg font-bold tracking-tight" aria-label="The Reflex Hub home">
            <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true" class="text-accent drop-shadow-[0_0_6px_var(--accent)]">
              <path d="M13 2 4.5 13.5H11L9.5 22 19 10h-6.5L13 2Z" fill="currentColor" />
            </svg>
            <span>The Reflex <span class="text-accent">Hub</span></span>
          </a>
          <p class="text-sm text-muted">Free reflex, reaction, typing, memory, and aim tests. Instant scores, real benchmarks.</p>
        </div>
        <div class="grid grid-cols-2 gap-8 sm:grid-cols-4">
          {footerGroups.map((group) => (
            <div>
              <p class="mb-3 font-display text-sm font-bold tracking-wide text-ink">{group.heading}</p>
              <ul class="flex flex-col gap-2">
                {group.links.map((l) => (
                  <li>
                    <a href={l.href} class="text-sm text-muted transition-colors hover:text-accent">
                      {l.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
        <p class="mt-8 border-t border-line pt-6 text-xs text-muted">
          The Reflex Hub offers free browser games that measure reaction time, clicking speed, typing speed, memory, and aim.
          Results are for fun and self-improvement only. Nothing on this site is a medical or psychological diagnostic tool.
        </p>
        <p class="mt-2 text-xs text-muted">Copyright {year} The Reflex Hub. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
